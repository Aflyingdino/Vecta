{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:js": "node --test tests/js/*.test.js",
    "test:php": "node run-php-tests.js",
    "test": "npm run test:js && npm run test:php",
    "lint:openapi": "npx --yes @redocly/cli@latest lint openapi.yaml",
    "check:frontend": "npm run build",
    "check:php": "node check-php.js",
    "check": "npm run check:frontend && npm run check:php && npm run test && npm run lint:openapi"
  },
  "dependencies": {
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
